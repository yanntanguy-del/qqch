#define MIN_WIDTH 64    // Largeur minimale de l'image
#define MAX_WIDTH 1024  // Largeur maximale de l'image

// Affiche le message d'aide du programme.
static void print_help(const char *progname) {
    fprintf(stderr, "Usage: %s <input_file> [output.png]\n", progname);
    fprintf(stderr, "Convertit un fichier binaire en image PNG.\n");
    fprintf(stderr, "Options:\n");
    fprintf(stderr, "  -h, --help    Affiche cette aide.\n");
}
// Lit tout le fichier en mémoire et renvoie un buffer alloué dynamiquement.

static uint8_t *read_file(const char *path, size_t *out_size) {
    FILE *f = fopen(path, "rb");                   // Ouvre le fichier en lecture binaire
    if (!f) {                                      // Si l'ouverture échoue
        perror("fopen");                           // Affiche la raison de l'erreur
        return NULL;                               // Signale l'échec
    }

    if (fseek(f, 0, SEEK_END) != 0) {              // Va à la fin pour connaître la taille
        perror("fseek");
        fclose(f);
        return NULL;
    }

    long len = ftell(f);                           // Récupère la taille du fichier
    if (len < 0) {                                 // Si ftell échoue
        perror("ftell");
        fclose(f);
        return NULL;
    }

    rewind(f);                                     // Revient au début du fichier

    if (len == 0) {                                // Refuse les fichiers vides
        fprintf(stderr, "Fichier vide\n");
        fclose(f);
        return NULL;
    }

    uint8_t *buf = malloc((size_t)len);            // Alloue un buffer de la bonne taille
    if (!buf) {                                    // Si malloc échoue
        fprintf(stderr, "malloc failed\n");
        fclose(f);
        return NULL;
    }

    size_t read = fread(buf, 1, (size_t)len, f);   // Lit tout le fichier dans le buffer
    if (read != (size_t)len) {                     // Vérifie que toute la lecture a réussi
        fprintf(stderr, "fread: expected %ld bytes, got %zu\n", len, read);
        free(buf);
        fclose(f);
        return NULL;
    }

    fclose(f);                                     // Ferme le fichier après lecture
    *out_size = (size_t)len;                       // Retourne la taille lue au code appelant
    return buf;                                    // Renvoie le buffer contenant les octets
}

// Vérifie si le fichier commence par la signature ELF.
static int is_elf(const uint8_t *data, size_t size) {
    if (size < 4) {                                // Il faut au moins 4 octets pour la signature
        return 0;
    }

    return data[0] == 0x7f &&                      // Premier octet ELF
           data[1] == 'E' &&                       // Deuxième octet ELF
           data[2] == 'L' &&                       // Troisième octet ELF
           data[3] == 'F';                         // Quatrième octet ELF
}

// Calcule une largeur d'image raisonnable à partir de la taille du fichier.
static int choose_width(size_t data_size) {
    double pixels = (double)data_size / 3.0;       // 3 octets par pixel RGB
    double root = sqrt(pixels);                    // Vise une forme proche d'un carré
    int w = (int)root;                             // Conversion en entier

    if (w < MIN_WIDTH) {                           // Empêche une image trop étroite
        w = MIN_WIDTH;
    }

    if (w > MAX_WIDTH) {                           // Empêche une image trop large
        w = MAX_WIDTH;
    }

    if (w % 16 != 0) {                             // Arrondit à un multiple de 16
        int mod = w % 16;
        if (mod < 8) {                             // Se rapproche du multiple inférieur
            w -= mod;
        } else {                                   // Sinon se rapproche du multiple supérieur
            w += (16 - mod);
        }
    }

    if (w < MIN_WIDTH) {                           // Sécurité finale après arrondi
        w = MIN_WIDTH;
    }

    if (w > MAX_WIDTH) {                           // Sécurité finale après arrondi
        w = MAX_WIDTH;
    }

    return w;                                      // Renvoie la largeur retenue
}

// Écrit le buffer binaire dans un PNG RGB.
static int write_png_rgb(const char *path,
                         const uint8_t *data,
                         size_t data_size,
                         int width,
                         int elf_hint) {
    FILE *fp = fopen(path, "wb");                  // Ouvre le fichier PNG de sortie
    if (!fp) {                                     // Si l'ouverture échoue
        perror("fopen");
        return 0;
    }

    png_structp png_ptr = png_create_write_struct(  // Crée la structure principale libpng
        PNG_LIBPNG_VER_STRING, NULL, NULL, NULL);
    if (!png_ptr) {                                // Si la création échoue
        fprintf(stderr, "png_create_write_struct failed\n");
        fclose(fp);
        return 0;
    }

    png_infop info_ptr = png_create_info_struct(png_ptr); // Crée la structure d'information PNG
    if (!info_ptr) {                               // Si la création échoue
        fprintf(stderr, "png_create_info_struct failed\n");
        png_destroy_write_struct(&png_ptr, NULL);  // Nettoie la structure principale
        fclose(fp);
        return 0;
    }
